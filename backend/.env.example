# Application
APP_NAME=Agentic Bay
APP_ENV=development
DEBUG=true
SECRET_KEY=change-this-to-a-secure-random-secret-key
JWT_SECRET=change-this-to-a-separate-secure-random-jwt-secret
API_V1_PREFIX=/api/v1

# Server
HOST=0.0.0.0
PORT=8000

# Database
# Use the Supabase "Direct connection" string if your runtime supports IPv6.
# Otherwise use the Supabase "Session pooler" string on port 5432.
# This backend is a long-running API service, so avoid the transaction pooler on port 6543 here.
# For the session pooler, the username looks like `postgres.<project-ref>`.
DATABASE_URL=postgresql+asyncpg://postgres.<project-ref>:<db-password>@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require
DATABASE_URL_SYNC=postgresql+psycopg2://postgres.<project-ref>:<db-password>@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require

# Redis
REDIS_URL=redis://localhost:6379/0

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# JWT
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_SECONDS=86400
REFRESH_TOKEN_EXPIRE_DAYS=30

# OAuth sign-in
# These endpoints should be the provider authorization URLs your frontend starts from.
GOOGLE_AUTH_URL=
FACEBOOK_AUTH_URL=

# Email OTP auth
EMAIL_OTP_EXPIRE_SECONDS=600
EMAIL_OTP_MAX_ATTEMPTS=5
EMAIL_OTP_RATE_LIMIT_WINDOW_SECONDS=900
EMAIL_OTP_RATE_LIMIT_MAX_REQUESTS=3

# Transactional email
RESEND_API_KEY=re_...
EMAIL_FROM_ADDRESS=noreply@yourdomain.com

# Orchestrator
ORCHESTRATOR_WS_URL=ws://localhost:8000

# ── Circle Developer-Controlled Wallets ───────────────────────────────────────
# API key from the Circle Developer Console
CIRCLE_API_KEY=

# Base URL — use sandbox for development, live for production
# Sandbox: https://api-sandbox.circle.com
# Live:    https://api.circle.com
CIRCLE_BASE_URL=https://api-sandbox.circle.com

# Entity secret: registered once in the Circle Console (keep secret, never commit)
CIRCLE_ENTITY_SECRET=

# Wallet set ID: the developer-controlled wallet set that owns all escrow wallets
CIRCLE_WALLET_SET_ID=

# ── Marketplace wallet ────────────────────────────────────────────────────────
# The platform's own wallet that receives marketplace fees
MARKETPLACE_WALLET_ID=
MARKETPLACE_WALLET_ADDRESS=

# Fee percentage charged to each transaction (default 5%)
MARKETPLACE_FEE_PERCENT=5.0

# ── Blockchain ────────────────────────────────────────────────────────────────
# Blockchain used for all escrow wallets (ARC-TESTNET for sandbox)
BLOCKCHAIN=ARC-TESTNET
INVOICE_CONTRACT_ADDRESS=

# ── Circle Webhooks ───────────────────────────────────────────────────────────
# HMAC-SHA256 signing secret from the Circle Console webhook configuration
CIRCLE_WEBHOOK_SECRET=
