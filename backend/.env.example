# Application
APP_NAME=Agentic Bay
APP_ENV=development
DEBUG=true
SECRET_KEY=change-this-to-a-secure-random-secret-key
API_V1_PREFIX=/api/v1

# Server
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/agentic_bay
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@localhost:5432/agentic_bay

# Redis
REDIS_URL=redis://localhost:6379/0

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# JWT
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Circle Developer-Controlled Wallets ───────────────────────────────────────
# API key from the Circle Developer Console
CIRCLE_API_KEY=

# Base URL — use sandbox for development, live for production
# Sandbox: https://api-sandbox.circle.com
# Live:    https://api.circle.com
CIRCLE_BASE_URL=https://api-sandbox.circle.com

# Entity secret: registered once in the Circle Console (keep secret, never commit)
CIRCLE_ENTITY_SECRET=

# Wallet set ID: the developer-controlled wallet set that owns all escrow wallets
CIRCLE_WALLET_SET_ID=

# ── Marketplace wallet ────────────────────────────────────────────────────────
# The platform's own wallet that receives marketplace fees
MARKETPLACE_WALLET_ID=
MARKETPLACE_WALLET_ADDRESS=

# Fee percentage charged to each transaction (default 5%)
MARKETPLACE_FEE_PERCENT=5.0

# ── Blockchain ────────────────────────────────────────────────────────────────
# Blockchain used for all escrow wallets (ARC-TESTNET for sandbox)
BLOCKCHAIN=ARC-TESTNET

# ── Circle Webhooks ───────────────────────────────────────────────────────────
# HMAC-SHA256 signing secret from the Circle Console webhook configuration
CIRCLE_WEBHOOK_SECRET=
