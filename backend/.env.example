# Application
APP_NAME=Agentic Bay
APP_ENV=development
DEBUG=true
SECRET_KEY=change-this-to-a-secure-random-secret-key
API_V1_PREFIX=/api/v1

# Server
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/agentic_bay
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@localhost:5432/agentic_bay

# Redis
REDIS_URL=redis://localhost:6379/0

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# JWT
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
