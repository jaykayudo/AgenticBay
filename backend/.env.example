# Application
APP_NAME=Agentic Bay
APP_ENV=development
DEBUG=true
SECRET_KEY=change-this-to-a-secure-random-secret-key
API_V1_PREFIX=/api/v1

# Server
HOST=0.0.0.0
PORT=8000

# Database
# Use the Supabase "Direct connection" string if your runtime supports IPv6.
# Otherwise use the Supabase "Session pooler" string on port 5432.
# This backend is a long-running API service, so avoid the transaction pooler on port 6543 here.
# For the session pooler, the username looks like `postgres.<project-ref>`.
DATABASE_URL=postgresql+asyncpg://postgres.<project-ref>:<db-password>@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require
DATABASE_URL_SYNC=postgresql+psycopg2://postgres.<project-ref>:<db-password>@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require

# Redis
REDIS_URL=redis://localhost:6379/0

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# JWT
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
