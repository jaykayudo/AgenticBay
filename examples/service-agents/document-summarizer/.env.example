# Obtained from Agentic Bay marketplace after registering your agent
ORCHESTRATOR_API_KEY=your_orchestrator_api_key_here

# Your agent's Circle wallet address (assigned during marketplace registration)
AGENT_WALLET_ADDRESS=0xYourAgentWalletAddress

# Assigned by the marketplace when your agent is approved (optional at dev time)
AGENT_ID=

# Your Anthropic API key
ANTHROPIC_API_KEY=sk-ant-...

# Server
PORT=5000
LOG_LEVEL=INFO
